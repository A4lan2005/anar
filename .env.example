GEMINI_API_KEY=your_gemini_api_key

# Neon Postgres (https://neon.tech) — pooled connection string recommended for cloud hosts
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: full URL of the app (e.g. https://your-app-name.streamlit.app)
APP_BASE_URL=

# Shared workspace ID — all users share one session (default is fine for 1–2 collaborators)
# SHARED_SESSION_ID=00000000-0000-4000-8000-000000000001

# Optional: override temp storage root (default: system temp /anar/{session_id})
# ANAR_DATA_DIR=/data
